# VirtFusion API
VF_API_URL=https://virtfusion.example/api/v1
VF_API_TOKEN=replace-me
VF_HYPERVISOR_ID=2
VF_PACKAGE_ID=1
VF_STORAGE_PROFILE_ID=
VF_NETWORK_PROFILE_ID=
VF_ADDITIONAL_STORAGE1_PROFILE_ID=
VF_ADDITIONAL_STORAGE2_PROFILE_ID=
VF_OS_TEMPLATE_ID=1

# Virtualizor database
VZ_MYSQL_BIN=/usr/local/emps/bin/mysql
VZ_DB_HOST=127.0.0.1
VZ_DB_PORT=3306
VZ_DB_NAME=virtualizor
VZ_DB_USER=virtualizor
VZ_DB_PASS=replace-me

# Ceph RBD access for image existence, copy, and temporary guest injection mapping
CEPH_USERNAME=cluster-user
CEPH_KEYRING=/etc/ceph/ceph.client.cluster-user.keyring

# WHMCS MySQL client
WHMCS_MYSQL_BIN=mysql

# WHMCS database A (required for all runs; used to resolve the existing customer identity)
WHMCS_A_DB_HOST=127.0.0.2
WHMCS_A_DB_PORT=3306
WHMCS_A_DB_NAME=whmcs_a
WHMCS_A_DB_USER=whmcs_a
WHMCS_A_DB_PASS=replace-me

# WHMCS database B (required for all runs; used when the service is not found in database A)
WHMCS_B_DB_HOST=127.0.0.3
WHMCS_B_DB_PORT=3306
WHMCS_B_DB_NAME=whmcs_b
WHMCS_B_DB_USER=whmcs_b
WHMCS_B_DB_PASS=replace-me

# Target WHMCS rewrite values for --whmcs only
# Copy whmcsmap.conf.example to a local whmcsmap.conf and edit that local file.
WHMCS_PRODUCT_MAP_FILE=whmcsmap.conf
WHMCS_A_TARGET_SERVER_ID=4
WHMCS_B_TARGET_SERVER_ID=9

# VirtFusion master helper (required only for execute-mode migrations that include IPv6; exact IPv4 preservation uses the public API only)
VF_MASTER_HOST=virtfusion-master.example
VF_MASTER_PORT=22
VF_MASTER_USER=root
VF_MASTER_HELPER_PATH=/opt/virtfusion/bin/virtfusion_master_ipv6_helper.php
VF_MASTER_PHP_BIN=/opt/virtfusion/php/bin/php
VF_MASTER_SSH_BIN=ssh
